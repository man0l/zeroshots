EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key

# Local Supabase (this repo's docker-compose): Kong is on host port 8080
# EXPO_PUBLIC_SUPABASE_URL=http://localhost:8080
# Android emulator: use 10.0.2.2 instead of localhost
# EXPO_PUBLIC_SUPABASE_URL=http://10.0.2.2:8080
