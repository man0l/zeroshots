# ─────────────────────────────────────────────
# Local Development (default)
# ─────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=http://localhost:8080
# Android emulator: localhost on host machine is 10.0.2.2
# EXPO_PUBLIC_SUPABASE_URL=http://10.0.2.2:8080
EXPO_PUBLIC_SUPABASE_ANON_KEY=<copy from supabase/.env ANON_KEY>
EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key
# Local: functions run without a prefix (standalone container)
EXPO_PUBLIC_EDGE_FUNCTION_PREFIX=

# ─────────────────────────────────────────────
# Production (Contabo / api.zenmanager.eu)
# Uncomment these and comment out the local block above
# ─────────────────────────────────────────────
# EXPO_PUBLIC_SUPABASE_URL=https://api.zenmanager.eu
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<production ANON_KEY from Contabo supabase/.env>
# EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key
# Production: SO functions are prefixed with "so-" to avoid collisions
# EXPO_PUBLIC_EDGE_FUNCTION_PREFIX=so-
