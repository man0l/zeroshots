############
# Database
############

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiJ9.6D7R0zBz6Q0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIn0.1
eGI0

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=Screenshot Organizer
STUDIO_DEFAULT_PROJECT=screenshot-organizer
# Kong is exposed on host port 8080 (see docker-compose: 8080:8000)
SUPABASE_PUBLIC_URL=http://localhost:8080
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_is_not_a_secure_password

############
# API
############

# Must match the URL used to reach Kong from outside (host port 8080 in this compose)
API_EXTERNAL_URL=http://localhost:8080
SECRET_KEY_BASE=up-to-you-but-at-least-64-characters

############
# Auth
############

SITE_URL=http://localhost:8081
# Comma-separated redirect URLs GoTrue allows after OAuth. Required for mobile Google sign-in.
# screenshot-organizer://** = direct app deep link; .../oauth-callback = proxy (code in path for Android).
# Port 8080 = Kong host port in this compose.
ADDITIONAL_REDIRECT_URLS=screenshot-organizer://**,http://localhost:8081/**,http://localhost:8080/functions/v1/oauth-callback,http://10.0.2.2:8080/functions/v1/oauth-callback
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

############
# SMTP (Optional - for email auth)
############

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender

############
# GitHub Auth (Optional)
############

ENABLE_GITHUB_AUTH=false
GITHUB_CLIENT_ID=
GITHUB_SECRET=

############
# Google Auth (Optional) - required for "Sign in with Google" in the app
############

ENABLE_GOOGLE_AUTH=true
# From Google Cloud Console: APIs & Services > Credentials > OAuth 2.0 Client ID.
# Use "Web application" (not Android) so you can set redirect URIs.
#
# Fix "Error 400: redirect_uri_mismatch": In Google Console > Credentials > your OAuth 2.0 Client ID
# (Web application) > Authorized redirect URIs, add EXACTLY this (copy-paste, no trailing slash):
#   http://localhost:8080/auth/v1/callback
# (Use 8080 because Kong is on host port 8080 in this compose.) Must match API_EXTERNAL_URL + /auth/v1/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

############
# Postgres
############

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

############
# Analytics
############

ANALYTICS_ACCESS_TOKEN=analytics_access_token
LOGFLARE_API_KEY=api_key
LOGFLARE_TOKEN=logflare_token
LOGFLARE_URL=http://analytics:4000
GOOGLE_PROJECT_ID=
GOOGLE_PROJECT_NUMBER=

############
# Vector
############

VECTOR_PORT=9001
